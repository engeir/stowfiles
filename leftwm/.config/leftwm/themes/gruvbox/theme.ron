#![enable(implicit_some)]
(
    border_width: 3,
    margin: 5,
    workspace_margin: 5,
    default_border_color: "#2a2318",
    floating_border_color: "#444444",
    focused_border_color: "#DA7510",
    on_new_window: "new_window_right",
    always_focus_new_windows: false,
    gutter: None,
    background_color: None,
)
