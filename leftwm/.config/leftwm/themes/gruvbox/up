#!/usr/bin/env bash
SCRIPTPATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

pkill -u "$USER" -x tint2 2>/dev/null
pkill -u "$USER" -x picom 2>/dev/null

picom --config "$HOME/.config/picom/picom.conf" &

tint2 -c "$SCRIPTPATH/tint2rc" &

pgrep -u "$USER" -x dunst         >/dev/null || dunst -conf "$HOME/.config/dunst/dunstrc" &
pgrep -u "$USER" -x nm-applet     >/dev/null || nm-applet --no-agent &
pgrep -u "$USER" -x blueman-applet >/dev/null || blueman-applet &
pgrep -u "$USER" -x clipcatd      >/dev/null || clipcatd &
pgrep -u "$USER" -x batsignal     >/dev/null || batsignal &

random_wallpaper 2>/dev/null &
